---
import BaseLayout from './BaseLayout.astro';

export interface Props {
  title: string;
  description: string;
  date: string;
  author?: string;
  image?: string;
  slug: string;
}

const {
  title,
  description,
  date,
  author = 'Mayprotec',
  image = '/og-default.jpg',
  slug,
} = Astro.props;

const canonical = `https://mallas-barranquilla.com/blog/${slug}`;
const dateISO   = new Date(date).toISOString();
const dateFmt   = new Date(date).toLocaleDateString('es-CO', { year: 'numeric', month: 'long', day: 'numeric' });

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": title,
  "description": description,
  "datePublished": dateISO,
  "dateModified": dateISO,
  "author": { "@type": "Organization", "name": "Mayprotec", "url": "https://mallas-barranquilla.com" },
  "publisher": { "@type": "Organization", "name": "Mayprotec", "logo": { "@type": "ImageObject", "url": "https://mallas-barranquilla.com/logo.svg" } },
  "image": `https://mallas-barranquilla.com${image}`,
  "mainEntityOfPage": { "@type": "WebPage", "@id": canonical },
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://mallas-barranquilla.com" },
    { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://mallas-barranquilla.com/blog" },
    { "@type": "ListItem", "position": 3, "name": title, "item": canonical },
  ]
};
---

<BaseLayout
  title={`${title} | Blog Mayprotec`}
  description={description}
  canonical={canonical}
  ogImage={image}
  schema={[articleSchema, breadcrumbSchema]}
>

  <article class="max-w-3xl mx-auto px-4 sm:px-6 py-16 md:py-24">

    <!-- Breadcrumb nav -->
    <nav aria-label="Ruta de navegación" class="mb-8">
      <ol class="flex items-center gap-2 text-xs text-ink-400 flex-wrap">
        <li><a href="/" class="hover:text-brand-primary transition-colors duration-200">Inicio</a></li>
        <li aria-hidden="true">/</li>
        <li><a href="/blog" class="hover:text-brand-primary transition-colors duration-200">Blog</a></li>
        <li aria-hidden="true">/</li>
        <li class="text-ink-DEFAULT font-medium truncate">{title}</li>
      </ol>
    </nav>

    <!-- Hero Image -->
    {image && (
      <div class="mb-10 -mx-4 sm:-mx-6">
        <img
          src={image}
          alt={title}
          class="w-full h-64 md:h-96 object-cover rounded-2xl shadow-2xl"
          loading="eager"
        />
      </div>
    )}

    <!-- Header -->
    <header class="mb-12 text-center">
      <h1 class="font-display font-bold text-3xl md:text-4xl lg:text-5xl text-ink leading-tight mb-6">
        {title}
      </h1>
      <p class="text-xl text-ink-600 leading-relaxed mb-8 max-w-2xl mx-auto">{description}</p>
      <div class="flex items-center justify-center gap-4 text-sm text-ink-400 pb-6 border-b border-ink-200">
        <time datetime={dateISO} class="flex items-center gap-2">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
            <line x1="16" y1="2" x2="16" y2="6"/>
            <line x1="8" y1="2" x2="8" y2="6"/>
            <line x1="3" y1="10" x2="21" y2="10"/>
          </svg>
          {dateFmt}
        </time>
        <span aria-hidden="true">·</span>
        <span class="flex items-center gap-2">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
            <circle cx="12" cy="7" r="4"/>
          </svg>
          Por {author}
        </span>
      </div>
    </header>

    <!-- Content -->
    <div class="
      prose prose-sm md:prose-base lg:prose-lg max-w-none
      prose-headings:font-display prose-headings:font-bold prose-headings:text-ink
      prose-h1:text-3xl prose-h1:mt-12 prose-h1:mb-6
      prose-h2:text-2xl prose-h2:mt-12 prose-h2:mb-6 prose-h2:border-b-2 prose-h2:border-brand-primary/20 prose-h2:pb-3
      prose-h3:text-xl prose-h3:mt-10 prose-h3:mb-4
      prose-p:text-ink-600 prose-p:leading-loose prose-p:mb-6
      prose-a:text-brand-primary prose-a:no-underline hover:prose-a:underline prose-a:transition-colors
      prose-strong:text-ink prose-strong:font-semibold
      prose-ul:text-ink-600 prose-li:mb-3 prose-li:leading-relaxed
      prose-ol:text-ink-600 prose-li:mb-3 prose-li:leading-relaxed
      prose-blockquote:border-l-4 prose-blockquote:border-brand-primary prose-blockquote:bg-brand-50 prose-blockquote:text-ink-600 prose-blockquote:py-4 prose-blockquote:px-6 prose-blockquote:my-8 prose-blockquote:rounded-r-lg
      prose-table:border-collapse prose-table:w-full prose-table:my-8
      prose-th:bg-brand-primary prose-th:text-white prose-th:font-semibold prose-th:px-4 prose-th:py-3
      prose-td:border prose-td:border-gray-200 prose-td:px-4 prose-td:py-3 prose-td:text-ink-600
      prose-code:bg-ink-100 prose-code:text-ink-800 prose-code:px-2 prose-code:py-1 prose-code:rounded prose-code:text-sm prose-code:font-mono
      prose-pre:bg-ink-900 prose-pre:text-white prose-pre:p-4 prose-pre:rounded-lg prose-pre:overflow-x-auto prose-pre:my-8
      prose-hr:border-ink-200 prose-hr:my-12
    ">
      <slot />
    </div>

    <!-- Back link + Internal CTA -->
    <footer class="mt-16 pt-8 border-t border-ink-200">
      <div class="bg-gradient-to-br from-brand-50 to-white rounded-2xl p-8 text-center border border-brand-primary/20 shadow-lg mb-8">
        <div class="inline-flex items-center justify-center w-16 h-16 bg-brand-primary rounded-full mb-4">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          </svg>
        </div>
        <h2 class="font-display font-bold text-2xl text-ink-DEFAULT mb-3">¿Necesitas mallas de seguridad en Barranquilla?</h2>
        <p class="text-ink-600 text-base mb-6 leading-relaxed">Somos especialistas en instalación de mallas para balcones, ventanas y terrazas. Cotización gratuita sin compromiso.</p>
        <a href="/" class="inline-flex items-center gap-2 bg-brand-primary hover:bg-brand-dark text-white px-8 py-4 rounded-lg font-semibold transition-all duration-200 transform hover:-translate-y-1 hover:shadow-xl">
          Ver servicios y cotizar
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"/>
            <polyline points="12 5 19 12 12 19"/>
          </svg>
        </a>
      </div>

      <div class="flex items-center justify-between">
        <a href="/blog" class="inline-flex items-center gap-2 text-sm text-ink-600 hover:text-brand-primary transition-colors duration-200 font-medium">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="19" y1="12" x2="5" y2="12"/>
            <polyline points="12 19 5 12 12 5"/>
          </svg>
          Volver al blog
        </a>

        <a href="/contacto" class="inline-flex items-center gap-2 text-sm text-brand-primary hover:text-brand-dark transition-colors duration-200 font-medium">
          Contáctanos
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="5" y1="12" x2="19" y2="12"/>
            <polyline points="12 5 19 12 12 19"/>
          </svg>
        </a>
      </div>
    </footer>
  </article>
</BaseLayout>