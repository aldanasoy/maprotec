---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
---

<BaseLayout
  title="Blog de mallas de seguridad | Mayprotec Barranquilla"
  description="Artículos y guías sobre mallas de seguridad para balcones, ventanas y mascotas en Barranquilla. Consejos de expertos para proteger tu hogar."
  canonical="https://mallas-barranquilla.com/blog"
>

  <section class="py-20 md:py-28 bg-gradient-to-b from-brand-50 to-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Hero section -->
      <div class="text-center mb-20">
        <div class="inline-flex items-center gap-2 bg-brand-primary/10 text-brand-primary px-4 py-2 rounded-full text-sm font-medium mb-6">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M19 21V5a2 2 0 0 0-2-2H7a2 2 0 0 0-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v5m-4 0h4"/>
          </svg>
          Blog
        </div>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-ink-900 mb-6">
          Guías y consejos sobre
          <br />
          <span class="text-brand-primary">mallas de seguridad</span>
        </h1>
        <p class="text-xl text-ink-600 max-w-3xl mx-auto leading-relaxed">
          Todo lo que necesitas saber para proteger tu hogar en Barranquilla con información actualizada y consejos de expertos.
        </p>
      </div>

      <!-- Blog grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {posts.map(post => (
          <article class="group bg-white rounded-2xl shadow-lg overflow-hidden hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-2">
            <!-- Image -->
            <div class="relative h-48 overflow-hidden">
              <img
                src={post.data.image ?? '/og-default.jpg'}
                alt={post.data.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
              />
              <!-- Date overlay -->
              <div class="absolute top-4 left-4 bg-white/95 backdrop-blur-sm px-3 py-1.5 rounded-lg text-sm font-medium text-ink-700">
                {new Date(post.data.date).toLocaleDateString('es-CO', { 
                  year: 'numeric', 
                  month: 'long', 
                  day: 'numeric' 
                })}
              </div>
            </div>

            <!-- Content -->
            <div class="p-6">
              <!-- Tags -->
              <div class="flex flex-wrap gap-2 mb-4">
                {post.data.tags.map(tag => (
                  <span class="px-2.5 py-1 bg-brand-primary/10 text-brand-primary text-xs font-medium rounded-full">
                    {tag}
                  </span>
                ))}
              </div>

              <!-- Title -->
              <h2 class="text-xl font-bold text-ink-900 mb-3 leading-tight group-hover:text-brand-primary transition-colors">
                {post.data.title}
              </h2>

              <!-- Description -->
              <p class="text-ink-600 text-sm leading-relaxed mb-4 flex-1">
                {post.data.description}
              </p>

              <!-- Read more -->
              <a href={`/blog/${post.id}`} class="inline-flex items-center gap-1.5 text-sm font-semibold text-brand-primary hover:text-brand-primary/80 transition-colors">
                Leer artículo completo
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform">
                  <line x1="5" y1="12" x2="19" y2="12"/>
                  <polyline points="12 5 19 12 12 19"/>
                </svg>
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 bg-brand-primary text-white">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold mb-4">¿Necesitas asesoramiento personalizado?</h2>
      <p class="text-lg mb-8 text-white/90">
        Nuestros expertos están listos para evaluar tu espacio y recomendarte la mejor solución.
      </p>
      <a href="/" class="inline-flex items-center gap-2 bg-white text-brand-primary px-6 py-3 rounded-lg font-semibold hover:bg-white/90 transition-colors">
        Solicita cotización gratuita
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12"/>
          <polyline points="12 5 19 12 12 19"/>
        </svg>
      </a>
    </div>
  </section>

</BaseLayout>