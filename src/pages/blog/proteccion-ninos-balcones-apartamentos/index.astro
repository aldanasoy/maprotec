---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getEntry } from 'astro:content';
import '../styles.css';

const entry = await getEntry('blog', 'proteccion-ninos-balcones-apartamentos');
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  canonical={`https://mallas-barranquilla.com/blog/${entry.slug}`}
>

  <!-- Hero section -->
  <section class="relative bg-gradient-to-br from-brand-50 to-white">
    <div class="max-w-4xl mx-auto px-4 py-16 sm:py-24">
      <!-- Breadcrumb -->
      <nav class="mb-8">
        <ol class="flex items-center gap-2 text-sm text-ink-500">
          <li><a href="/" class="hover:text-brand-primary transition-colors">Inicio</a></li>
          <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mx-1">
            <polyline points="9 18 15 12 9 6"/>
          </svg></li>
          <li><a href="/blog" class="hover:text-brand-primary transition-colors">Blog</a></li>
          <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mx-1">
            <polyline points="9 18 15 12 9 6"/>
          </svg></li>
          <li class="text-ink-700">{entry.data.title}</li>
        </ol>
      </nav>

      <!-- Content -->
      <article class="prose prose-lg max-w-none">
        <!-- Meta information -->
        <div class="flex flex-wrap items-center gap-4 mb-8 text-sm text-ink-500">
          <div class="flex items-center gap-2">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect width="18" height="18" x="3" y="4" rx="2" ry="2"/>
              <line x1="16" y1="2" x2="16" y2="6"/>
              <line x1="8" y1="2" x2="8" y2="6"/>
              <line x1="3" y1="10" x2="21" y2="10"/>
            </svg>
            {new Date(entry.data.date).toLocaleDateString('es-CO', { 
              year: 'numeric', 
              month: 'long', 
              day: 'numeric' 
            })}
          </div>
          <div class="flex items-center gap-2">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
              <circle cx="12" cy="7" r="4"/>
            </svg>
            Por {entry.data.author}
          </div>
        </div>

        <!-- Title -->
        <h1 class="text-4xl md:text-5xl font-bold text-ink-900 mb-8 leading-tight">
          {entry.data.title}
        </h1>

        <!-- Image -->
        {entry.data.image && (
          <div class="mb-8 rounded-2xl overflow-hidden shadow-xl">
            <img
              src={entry.data.image}
              alt={entry.data.title}
              class="w-full h-64 md:h-96 object-cover"
              loading="lazy"
            />
          </div>
        )}

        <!-- Tags -->
        {entry.data.tags.length > 0 && (
          <div class="flex flex-wrap gap-2 mb-8">
            {entry.data.tags.map(tag => (
              <span class="px-3 py-1 bg-brand-primary/10 text-brand-primary text-sm font-medium rounded-full">
                #{tag}
              </span>
            ))}
          </div>
        )}

        <!-- Content -->
        <Fragment set:html={entry.body} />

        <!-- Share buttons -->
        <div class="mt-16 pt-8 border-t border-gray-200">
          <h3 class="text-lg font-semibold text-ink-900 mb-4">Compartir artículo</h3>
          <div class="flex gap-4">
            <a href="#" class="flex items-center gap-2 px-4 py-2 bg-gray-100 rounded-lg hover:bg-gray-200 transition-colors">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
              </svg>
              Facebook
            </a>
            <a href="#" class="flex items-center gap-2 px-4 py-2 bg-gray-100 rounded-lg hover:bg-gray-200 transition-colors">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
                <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
                <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
              </svg>
              Instagram
            </a>
            <a href="#" class="flex items-center gap-2 px-4 py-2 bg-gray-100 rounded-lg hover:bg-gray-200 transition-colors">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
              </svg>
              WhatsApp
            </a>
          </div>
        </div>
      </article>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-brand-primary text-white">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold mb-4">¿Listo para proteger tu hogar?</h2>
      <p class="text-lg mb-8 text-white/90">
        ¡Contáctanos hoy mismo para una cotización gratuita y sin compromiso!
      </p>
      <button
        data-open-lead-modal
        class="inline-flex items-center gap-2 bg-white text-brand-primary px-6 py-3 rounded-lg font-semibold hover:bg-white/90 transition-colors"
      >
        Solicita cotización ahora
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12"/>
          <polyline points="12 5 19 12 12 19"/>
        </svg>
      </button>
    </div>
  </section>

</BaseLayout>