---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Cotizacion recibida | Maprotec"
  description="Recibimos tu solicitud. Te contactaremos en menos de 2 horas."
  canonical="https://maprotec.co/gracias"
  noindex={true}
>
  <section class="min-h-[70vh] flex items-center justify-center py-20 px-4">
    <div class="text-center max-w-md">
      <div class="w-16 h-16 bg-brand-50 rounded-full flex items-center justify-center mx-auto mb-6">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#059669" stroke-width="2.5" stroke-linecap="round">
          <polyline points="20 6 9 17 4 12"/>
        </svg>
      </div>
      <h1 class="font-display font-bold text-3xl text-ink mb-3">Solicitud recibida</h1>
      <p class="text-ink-600 mb-8">Gracias por contactarnos. Un asesor de Maprotec te contactara en menos de 2 horas para coordinar la visita tecnica gratuita.</p>
      <a href="/" class="btn-primary">Volver al inicio</a>
    </div>
  </section>
</BaseLayout>
