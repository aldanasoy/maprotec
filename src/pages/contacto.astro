---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/home/ContactForm.astro';
---

<BaseLayout
  title="Contacto | Mayprotec — Mallas de seguridad Barranquilla"
  description="Contacta a Mayprotec para cotizar mallas de seguridad en Barranquilla. Respondemos en menos de 2 horas. Visita tecnica gratuita sin compromiso."
  canonical="https://mallas-barranquilla.com/contacto"
>
  <section class="py-16 bg-white">
    <div class="max-w-2xl mx-auto px-4 text-center">
      <span class="section-label">Hablemos</span>
      <h1 class="section-title mx-auto mt-2">
        Cotiza tus<br />
        <span class="text-brand-dark">mallas de seguridad</span>
      </h1>
      <p class="section-subtitle mx-auto mt-4 text-center">
        Completa el formulario, escribe por WhatsApp o llámanos. Respondemos rápido.
      </p>
    </div>
  </section>
  <ContactForm />
</BaseLayout>
