---
// LeadModal.astro — Sistema de captación de leads para Mayprotec
// Inspired by Repararya's modal system
// Backend: Telegram (live) + Supabase + GestionaLeads (config via env)
---

<!-- Trigger button para añadir en cualquier sección -->
<slot />

<!-- ══════════════════════════════════════════
     MODAL OVERLAY
════════════════════════════════════════════ -->
<div
  id="lead-modal"
  role="dialog"
  aria-modal="true"
  aria-labelledby="modal-title"
  class="fixed inset-0 z-[9999] hidden"
>
  <!-- Backdrop -->
  <div
    id="modal-backdrop"
    class="absolute inset-0 bg-ink-DEFAULT/70 backdrop-blur-sm"
  ></div>

  <!-- Panel -->
  <div class="relative flex items-center justify-center min-h-screen p-4">
    <div
      id="modal-panel"
      class="relative w-full max-w-lg bg-white rounded-3xl shadow-2xl overflow-hidden
             transform transition-all duration-300 scale-95 opacity-0"
    >
      <!-- Header gradient bar -->
      <div class="h-1.5 bg-gradient-to-r from-brand-dark via-brand to-brand-light"></div>

      <!-- Close button -->
      <button
        id="modal-close"
        class="absolute top-4 right-4 w-9 h-9 rounded-full bg-ink-200/60 flex items-center
               justify-center text-ink-600 hover:bg-ink-200 hover:text-ink transition-all"
        aria-label="Cerrar"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="2" stroke-linecap="round">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>

      <!-- ── STEP 1: Form ── -->
      <div id="modal-step-form" class="p-8">
        <!-- Top -->
        <div class="flex items-start gap-4 mb-6">
          <div class="w-12 h-12 rounded-2xl bg-brand-50 flex items-center justify-center flex-shrink-0">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#16a34a"
                 stroke-width="2" stroke-linecap="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
          </div>
          <div>
            <h2 id="modal-title" class="font-display font-bold text-xl text-ink">
              Cotizacion gratis
            </h2>
            <p class="text-sm text-ink-500 mt-0.5">
              Respuesta en menos de 2 horas &middot; Sin compromiso
            </p>
          </div>
        </div>

        <!-- Form -->
        <form id="modal-form" novalidate>
          <div class="space-y-4">
            <!-- Nombre + Telefono -->
            <div class="grid grid-cols-2 gap-3">
              <div>
                <label for="modal-nombre" class="block text-xs font-semibold text-ink mb-1">
                  Nombre <span class="text-brand">*</span>
                </label>
                <input
                  type="text" id="modal-nombre" name="nombre" required
                  placeholder="Tu nombre"
                  class="w-full px-3.5 py-2.5 rounded-xl border border-ink-200 text-sm
                         focus:outline-none focus:border-brand focus:ring-2 focus:ring-brand/20
                         transition-all placeholder:text-ink-300"
                />
              </div>
              <div>
                <label for="modal-telefono" class="block text-xs font-semibold text-ink mb-1">
                  WhatsApp <span class="text-brand">*</span>
                </label>
                <input
                  type="tel" id="modal-telefono" name="telefono" required
                  placeholder="300 000 0000"
                  class="w-full px-3.5 py-2.5 rounded-xl border border-ink-200 text-sm
                         focus:outline-none focus:border-brand focus:ring-2 focus:ring-brand/20
                         transition-all placeholder:text-ink-300"
                />
              </div>
            </div>

            <!-- Servicio -->
            <div>
              <label for="modal-servicio" class="block text-xs font-semibold text-ink mb-1">
                Que necesitas instalar <span class="text-brand">*</span>
              </label>
              <select
                id="modal-servicio" name="servicio" required
                class="w-full px-3.5 py-2.5 rounded-xl border border-ink-200 text-sm text-ink-600
                       focus:outline-none focus:border-brand focus:ring-2 focus:ring-brand/20
                       transition-all bg-white"
              >
                <option value="" disabled selected>Selecciona una opcion</option>
                <option value="balcon">Malla para balcon</option>
                <option value="ventana">Malla para ventana</option>
                <option value="terraza">Malla para terraza</option>
                <option value="apartamento">Apartamento completo</option>
                <option value="casa">Casa</option>
              </select>
            </div>

            <!-- Zona -->
            <div>
              <label for="modal-zona" class="block text-xs font-semibold text-ink mb-1">
                Barrio o zona en Barranquilla
              </label>
              <input
                type="text" id="modal-zona" name="zona"
                placeholder="El Prado, Norte, Altamira..."
                class="w-full px-3.5 py-2.5 rounded-xl border border-ink-200 text-sm
                       focus:outline-none focus:border-brand focus:ring-2 focus:ring-brand/20
                       transition-all placeholder:text-ink-300"
              />
            </div>

            <!-- Mensaje opcional -->
            <div>
              <label for="modal-mensaje" class="block text-xs font-semibold text-ink mb-1">
                Detalles adicionales <span class="text-ink-400 font-normal">(opcional)</span>
              </label>
              <textarea
                id="modal-mensaje" name="mensaje" rows="2"
                placeholder="Cuantos balcones, piso, tipo de edificio..."
                class="w-full px-3.5 py-2.5 rounded-xl border border-ink-200 text-sm
                       focus:outline-none focus:border-brand focus:ring-2 focus:ring-brand/20
                       transition-all resize-none placeholder:text-ink-300"
              ></textarea>
            </div>
          </div>

          <!-- Error message -->
          <div id="modal-error" class="hidden mt-3 p-3 rounded-xl bg-red-50 border border-red-200
               text-xs text-red-600 flex items-center gap-2">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                 stroke-width="2" stroke-linecap="round" class="flex-shrink-0">
              <circle cx="12" cy="12" r="10"/>
              <line x1="15" y1="9" x2="9" y2="15"/>
              <line x1="9" y1="9" x2="15" y2="15"/>
            </svg>
            <span id="modal-error-text">Por favor completa todos los campos requeridos.</span>
          </div>

          <!-- Submit -->
          <button
            type="submit"
            id="modal-submit"
            class="mt-5 btn-primary w-full justify-center py-3.5 text-base font-semibold"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                 stroke-width="2" stroke-linecap="round" aria-hidden="true">
              <line x1="22" y1="2" x2="11" y2="13"/>
              <polygon points="22 2 15 22 11 13 2 9 22 2"/>
            </svg>
            <span id="modal-btn-text">Solicitar cotizacion gratis</span>
          </button>

          <p class="text-center text-xs text-ink-400 mt-3">
            Al enviar aceptas nuestra
            <a href="/politica-privacidad" class="text-brand hover:underline" target="_blank">
              politica de privacidad
            </a>
          </p>
        </form>
      </div>

      <!-- ── STEP 2: Success ── -->
      <div id="modal-step-success" class="hidden p-8 text-center">
        <div class="w-16 h-16 rounded-full bg-brand/10 flex items-center justify-center mx-auto mb-5">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#16a34a"
               stroke-width="2.5" stroke-linecap="round" class="animate-in zoom-in-50 duration-300">
            <polyline points="20 6 9 17 4 12"/>
          </svg>
        </div>
        <h3 class="font-display font-bold text-2xl text-ink mb-2">
          Recibimos tu solicitud
        </h3>
        <p class="text-ink-500 text-sm leading-relaxed mb-6">
          Gracias <strong id="success-name" class="text-ink"></strong>. Uno de nuestros asesores
          te contactara por WhatsApp en menos de 2 horas.
        </p>

        <!-- WhatsApp CTA -->
        <a
          id="success-wa-link"
          href="#"
          target="_blank"
          rel="noopener"
          class="btn-whatsapp w-full justify-center mb-3"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347zM12.004 0C5.374 0 0 5.373 0 12c0 2.117.554 4.107 1.524 5.836L.051 23.625a.75.75 0 00.918.918l5.818-1.476A11.955 11.955 0 0012.004 24C18.633 24 24 18.627 24 12S18.633 0 12.004 0z"/>
          </svg>
          Escribir por WhatsApp ahora
        </a>

        <button
          id="modal-reset"
          class="text-sm text-ink-400 hover:text-ink transition-colors"
        >
          Hacer otra consulta
        </button>
      </div>
    </div>
  </div>
</div>

<!-- ══════════════════════════════════════════
     LEAD SUBMISSION SCRIPT
════════════════════════════════════════════ -->
<script>
// ─── Config ──────────────────────────────────────────────────────────────────
const CFG = {
  // Telegram — alerts to Sergio (ManagitoBot)
  TG_BOT: '8690717519:AAGqBWOPN-YuSZJkjqjv5yqrFN01mFiG_54',
  TG_CHAT: '6117124891',          // Sergio personal — cambiar a chat Mayas cuando Sergio cree el grupo
  // WhatsApp del negocio (reemplazar con número real)
  WA_NUMBER: '[WHATSAPP_NUM]',
  // Supabase (activar cuando Sergio provea keys)
  SUPABASE_URL: '',
  SUPABASE_KEY: '',
  // GestionaLeads (activar cuando Sergio provea token)
  GL_TOKEN: '',
};

// ─── Modal state ──────────────────────────────────────────────────────────────
const modal   = document.getElementById('lead-modal')!;
const panel   = document.getElementById('modal-panel')!;
const form    = document.getElementById('modal-form')!;
const stepForm    = document.getElementById('modal-step-form')!;
const stepSuccess = document.getElementById('modal-step-success')!;
const submitBtn   = document.getElementById('modal-submit')!;
const btnText     = document.getElementById('modal-btn-text')!;
const errorEl     = document.getElementById('modal-error')!;
const errorText   = document.getElementById('modal-error-text')!;

// ─── Open / Close ─────────────────────────────────────────────────────────────
function openModal() {
  modal.classList.remove('hidden');
  document.body.style.overflow = 'hidden';
  // Animate in
  setTimeout(() => {
    panel.classList.remove('scale-95', 'opacity-0');
    panel.classList.add('scale-100', 'opacity-100');
    (document.getElementById('modal-nombre') as HTMLInputElement)?.focus();
  }, 10);
}

function closeModal() {
  panel.classList.remove('scale-100', 'opacity-100');
  panel.classList.add('scale-95', 'opacity-0');
  setTimeout(() => {
    modal.classList.add('hidden');
    document.body.style.overflow = '';
    resetModal();
  }, 200);
}

function resetModal() {
  (form as HTMLFormElement).reset();
  stepForm.classList.remove('hidden');
  stepSuccess.classList.add('hidden');
  errorEl.classList.add('hidden');
  btnText.textContent = 'Solicitar cotizacion gratis';
  submitBtn.removeAttribute('disabled');
}

// ─── Event listeners ─────────────────────────────────────────────────────────
document.getElementById('modal-close')?.addEventListener('click', closeModal);
document.getElementById('modal-backdrop')?.addEventListener('click', closeModal);
document.getElementById('modal-reset')?.addEventListener('click', () => {
  stepSuccess.classList.add('hidden');
  stepForm.classList.remove('hidden');
  (form as HTMLFormElement).reset();
});

// Close on Escape
document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });

// All trigger buttons with data-open-lead-modal
document.querySelectorAll('[data-open-lead-modal]').forEach(btn => {
  btn.addEventListener('click', e => { e.preventDefault(); openModal(); });
});

// ─── Form submit ─────────────────────────────────────────────────────────────
form.addEventListener('submit', async (e) => {
  e.preventDefault();
  const fd = new FormData(form as HTMLFormElement);
  const data = Object.fromEntries(fd.entries());

  // Basic validation
  if (!data.nombre || !data.telefono || !data.servicio) {
    errorText.textContent = 'Por favor completa nombre, WhatsApp y tipo de instalacion.';
    errorEl.classList.remove('hidden');
    return;
  }
  errorEl.classList.add('hidden');

  // Loading state
  submitBtn.setAttribute('disabled', 'true');
  btnText.textContent = 'Enviando...';

  const timestamp = new Date().toLocaleString('es-CO', { timeZone: 'America/Bogota' });

  try {
    // ── 1. Telegram alert (live) ────────────────────────────────────────────
    const tgMsg =
      `*Nuevo Lead - Mayprotec (BAQ)*\n\n` +
      `Nombre: ${data.nombre}\n` +
      `WhatsApp: ${data.telefono}\n` +
      `Servicio: ${data.servicio}\n` +
      `Zona: ${data.zona || '-'}\n` +
      `Detalles: ${data.mensaje || '-'}\n\n` +
      `Hora: ${timestamp}\n` +
      `Fuente: mallas-barranquilla.com`;

    await fetch(`https://api.telegram.org/bot${CFG.TG_BOT}/sendMessage`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        chat_id: CFG.TG_CHAT,
        text: tgMsg,
        parse_mode: 'Markdown',
      }),
    }).catch(() => {}); // fail silently — user experience is priority

    // ── 2. Supabase (when keys are provided) ────────────────────────────────
    if (CFG.SUPABASE_URL && CFG.SUPABASE_KEY) {
      await fetch(`${CFG.SUPABASE_URL}/rest/v1/mayprotec_leads`, {
        method: 'POST',
        headers: {
          'apikey': CFG.SUPABASE_KEY,
          'Authorization': `Bearer ${CFG.SUPABASE_KEY}`,
          'Content-Type': 'application/json',
          'Prefer': 'return=minimal',
        },
        body: JSON.stringify({
          nombre: data.nombre,
          telefono: data.telefono,
          servicio: data.servicio,
          zona: data.zona || null,
          mensaje: data.mensaje || null,
          fuente: 'mallas-barranquilla.com',
          created_at: new Date().toISOString(),
        }),
      }).catch(() => {});
    }

    // ── 3. GestionaLeads (when token is provided) ────────────────────────────
    if (CFG.GL_TOKEN) {
      await fetch(`https://gestionaleads.es/api/in/${CFG.GL_TOKEN}/lead/web`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          nombre: data.nombre,
          telefono: data.telefono,
          email: '',
          fuente: 'mallas-barranquilla.com',
          notas: `Servicio: ${data.servicio}. Zona: ${data.zona}. ${data.mensaje}`,
        }),
      }).catch(() => {});
    }

    // ── Show success ─────────────────────────────────────────────────────────
    (document.getElementById('success-name') as HTMLElement).textContent =
      (data.nombre as string).split(' ')[0];

    const waMsg = encodeURIComponent(
      `Hola, soy ${data.nombre}. Acabo de solicitar una cotizacion en mallas-barranquilla.com para ${data.servicio} en ${data.zona || 'Barranquilla'}.`
    );
    (document.getElementById('success-wa-link') as HTMLAnchorElement).href =
      `https://wa.me/${CFG.WA_NUMBER}?text=${waMsg}`;

    stepForm.classList.add('hidden');
    stepSuccess.classList.remove('hidden');

  } catch {
    errorText.textContent = 'Ocurrio un error. Por favor intentalo de nuevo.';
    errorEl.classList.remove('hidden');
    submitBtn.removeAttribute('disabled');
    btnText.textContent = 'Solicitar cotizacion gratis';
  }
});
</script>
