---
const navLinks = [
  { href: '/',          label: 'Inicio' },
  { href: '/precios',   label: 'Precios' },
  { href: '/galeria',   label: 'Galería' },
  { href: '/nosotros',  label: 'Nosotros' },
  { href: '/blog',      label: 'Blog' },
  { href: '/contacto',  label: 'Contacto' },
];
const currentPath = Astro.url.pathname;
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300" data-header>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <nav class="flex items-center justify-between h-16 md:h-20" aria-label="Navegación principal">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 group" aria-label="Maprotec - Inicio">
        <div class="w-8 h-8 bg-brand-dark rounded-lg flex items-center justify-center group-hover:bg-brand transition-colors">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/>
          </svg>
        </div>
        <span class="font-display font-bold text-lg text-ink-DEFAULT group-hover:text-brand-dark transition-colors">
          Maprotec
        </span>
      </a>

      <!-- Desktop Nav -->
      <ul class="hidden md:flex items-center gap-1" role="list">
        {navLinks.map(link => (
          <li>
            <a
              href={link.href}
              class={[
                'px-3 py-2 rounded-lg text-sm font-medium transition-all duration-200',
                currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
                  ? 'bg-brand-50 text-brand-dark font-semibold'
                  : 'text-ink-600 hover:text-ink-DEFAULT hover:bg-ink-200/50'
              ].join(' ')}
              aria-current={currentPath === link.href ? 'page' : undefined}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>

      <!-- CTA + Mobile menu btn -->
      <div class="flex items-center gap-3">
        <a href="/#contacto" class="hidden sm:flex btn-primary text-sm px-5 py-2.5 no-print">
          Cotización gratis
        </a>
        <button
          id="menu-toggle"
          class="md:hidden p-2 rounded-lg text-ink-600 hover:text-ink-DEFAULT hover:bg-ink-200/50 transition-colors"
          aria-label="Abrir menú"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <svg id="icon-menu" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
          </svg>
          <svg id="icon-close" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="hidden">
            <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
      </div>
    </nav>
  </div>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="md:hidden hidden border-t border-ink-200/60 bg-white shadow-lg"
    aria-hidden="true"
  >
    <ul class="px-4 py-4 space-y-1" role="list">
      {navLinks.map(link => (
        <li>
          <a
            href={link.href}
            class="flex items-center px-4 py-3 rounded-xl text-sm font-medium text-ink-600 hover:text-ink-DEFAULT hover:bg-brand-50 transition-all"
          >
            {link.label}
          </a>
        </li>
      ))}
      <li class="pt-2">
        <a href="/#contacto" class="btn-primary w-full justify-center">
          Cotización gratis
        </a>
      </li>
    </ul>
  </div>
</header>

<!-- Header spacer -->
<div class="h-16 md:h-20" aria-hidden="true"></div>

<script>
  // Scroll behaviour
  const header = document.querySelector('[data-header]') as HTMLElement;
  let lastY = 0;
  const onScroll = () => {
    const y = window.scrollY;
    if (y > 60) {
      header.classList.add('bg-white/95', 'backdrop-blur-md', 'shadow-sm', 'border-b', 'border-ink-200/60');
    } else {
      header.classList.remove('bg-white/95', 'backdrop-blur-md', 'shadow-sm', 'border-b', 'border-ink-200/60');
    }
    lastY = y;
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  // Mobile menu
  const toggle = document.getElementById('menu-toggle')!;
  const menu   = document.getElementById('mobile-menu')!;
  const iconM  = document.getElementById('icon-menu')!;
  const iconC  = document.getElementById('icon-close')!;

  toggle.addEventListener('click', () => {
    const open = !menu.classList.contains('hidden');
    menu.classList.toggle('hidden', open);
    menu.setAttribute('aria-hidden', String(open));
    toggle.setAttribute('aria-expanded', String(!open));
    iconM.classList.toggle('hidden', !open);
    iconC.classList.toggle('hidden', open);
  });
</script>
