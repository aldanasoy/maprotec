---
import Logo from './Logo.astro';
const year = new Date().getFullYear();
---

<footer class="bg-ink-DEFAULT text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">

      <!-- Brand -->
      <div class="lg:col-span-2">
        <div class="mb-4">
          <Logo showText={true} size={36} variant="white" />
        </div>
        <p class="text-ink-400 text-sm leading-relaxed max-w-xs">
          Empresa especializada en instalación de mallas de seguridad para balcones, ventanas y terrazas en Barranquilla y el Atlántico.
        </p>
        <div class="mt-6 space-y-2 text-sm">
          <p class="flex items-center gap-2 text-ink-400">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="flex-shrink-0"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.63A2 2 0 012 1h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.91 8.08a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
            [TELEFONO]
          </p>
          <p class="flex items-center gap-2 text-ink-400">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="flex-shrink-0"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            info@mallas-barranquilla.com
          </p>
          <p class="flex items-center gap-2 text-ink-400">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="flex-shrink-0"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
            Barranquilla, Atlántico, Colombia
          </p>
        </div>
      </div>

      <!-- Servicios -->
      <div>
        <h3 class="font-semibold text-sm uppercase tracking-wider text-ink-400 mb-4">Servicios</h3>
        <ul class="space-y-2 text-sm text-ink-400">
          {[
            ['/#tipos', 'Mallas para balcones'],
            ['/#tipos', 'Mallas para ventanas'],
            ['/#tipos', 'Mallas para terrazas'],
            ['/#tipos', 'Protección para mascotas'],
            ['/#tipos', 'Protección para niños'],
            ['/precios', 'Ver precios'],
          ].map(([href, label]) => (
            <li>
              <a href={href} class="hover:text-brand-primary transition-colors">{label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Empresa -->
      <div>
        <h3 class="font-semibold text-sm uppercase tracking-wider text-ink-400 mb-4">Empresa</h3>
        <ul class="space-y-2 text-sm text-ink-400">
          {[
            ['/nosotros',  'Nosotros'],
            ['/galeria',   'Galería de trabajos'],
            ['/blog',      'Blog'],
            ['/contacto',  'Contacto'],
            ['/politica-privacidad', 'Privacidad'],
          ].map(([href, label]) => (
            <li>
              <a href={href} class="hover:text-brand-primary transition-colors">{label}</a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 pt-8 border-t border-white/10 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-ink-400">
      <div class="flex flex-col sm:flex-row items-center gap-4 w-full sm:w-auto">
        <p>&copy; {year} Mayprotec. Todos los derechos reservados.</p>
        <button
          data-open-lead-modal
          class="bg-brand-primary hover:bg-brand-dark text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors flex items-center gap-2 whitespace-nowrap"
          aria-label="Abrir modal de WhatsApp"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347zM12 0C5.373 0 0 5.373 0 12c0 2.117.554 4.107 1.524 5.836L.051 23.625a.75.75 0 00.918.918l5.818-1.476A11.955 11.955 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/>
          </svg>
          WhatsApp: [TELEFONO]
        </button>
      </div>
      <p class="text-xs">Mallas para balcones en Barranquilla — Instalación profesional con garantía</p>
    </div>
  </div>
</footer>
