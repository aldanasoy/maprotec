---
export interface Props {
  phone: string;
  message?: string;
}
const {
  phone,
  message = 'Hola, me interesa una cotización para mallas de seguridad en Barranquilla.',
} = Astro.props;
const url = `https://wa.me/${phone}?text=${encodeURIComponent(message)}`;
---

<a
  href={url}
  target="_blank"
  rel="noopener noreferrer"
  class="no-print fixed bottom-6 right-6 z-50 group"
  aria-label="Chatea por WhatsApp"
  id="wa-float"
>
  <!-- Tooltip -->
  <span
    class="absolute right-14 bottom-1/2 translate-y-1/2 bg-ink-DEFAULT text-white text-xs font-medium
           px-3 py-1.5 rounded-lg whitespace-nowrap opacity-0 group-hover:opacity-100 transition-opacity
           pointer-events-none shadow-lg"
    aria-hidden="true"
  >
    Cotización por WhatsApp
  </span>

  <!-- Ripple -->
  <span class="absolute inset-0 rounded-full bg-[#25D366] animate-ping opacity-30" aria-hidden="true"></span>

  <!-- Button -->
  <span class="relative flex items-center justify-center w-14 h-14 bg-[#25D366] rounded-full shadow-xl
               hover:bg-[#1ebe5c] active:scale-95 transition-all duration-200">
    <svg width="26" height="26" viewBox="0 0 24 24" fill="white" aria-hidden="true">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
      <path d="M12.004 0C5.374 0 0 5.373 0 12c0 2.117.554 4.107 1.524 5.836L.051 23.625a.75.75 0 00.918.918l5.818-1.476A11.955 11.955 0 0012.004 24C18.633 24 24 18.627 24 12S18.633 0 12.004 0zm0 21.818a9.822 9.822 0 01-5.028-1.383l-.36-.214-3.73.946.988-3.612-.234-.372A9.816 9.816 0 012.182 12c0-5.417 4.406-9.818 9.822-9.818 5.416 0 9.814 4.401 9.814 9.818 0 5.416-4.398 9.818-9.814 9.818z"/>
    </svg>
  </span>
</a>
