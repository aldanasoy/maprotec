---
const benefits = [
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>`,
    title: 'Protege a tus hijos',
    desc: 'Barreras seguras que evitan accidentes en balcones y ventanas.'
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>`,
    title: 'Protege a tus mascotas',
    desc: 'Mallas especiales para gatos y perros que quieren explorar desde las alturas.'
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>`,
    title: 'Material anti-UV',
    desc: 'Polipropileno de alta densidad que resiste el sol del Caribe sin deformarse.'
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>`,
    title: 'Instalación certificada',
    desc: 'Técnicos capacitados y herramientas profesionales para cada tipo de estructura.'
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
    title: 'Garantía 1 año',
    desc: 'Respaldo total en materiales e instalación. Si algo falla, lo resolvemos gratis.'
  },
];
---

<section class="py-16 bg-ink-DEFAULT" id="beneficios" aria-labelledby="benefits-heading">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 id="benefits-heading" class="sr-only">Beneficios de nuestras mallas de seguridad</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-6">
      {benefits.map((b, i) => (
        <div
          class={`aos aos-delay-${i+1} flex flex-col items-start gap-3 p-6 rounded-2xl border border-white/10 hover:border-brand/50 hover:bg-white/5 transition-all duration-300`}
        >
          <div class="w-10 h-10 flex items-center justify-center rounded-xl bg-brand/10 text-brand" set:html={b.icon} />
          <h3 class="text-white font-semibold text-sm">{b.title}</h3>
          <p class="text-ink-400 text-xs leading-relaxed">{b.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
