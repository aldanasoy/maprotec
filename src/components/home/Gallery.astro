---
const works = [
  {
    img: '/images/galeria-1.jpg',
    alt: 'Malla de seguridad instalada en balcon apartamento norte Barranquilla',
    label: 'Balcon Norte BAQ',
    tipo: 'Malla anti-caida',
  },
  {
    img: '/images/galeria-2.jpg',
    alt: 'Malla protectora para ventana edificio residencial Barranquilla',
    label: 'Ventanas edificio',
    tipo: 'Malla ventanas',
  },
  {
    img: '/images/galeria-3.jpg',
    alt: 'Terraza protegida con malla de seguridad para mascotas',
    label: 'Terraza con mascotas',
    tipo: 'Protección mascotas',
  },
  {
    img: '/images/galeria-4.jpg',
    alt: 'Instalación malla balcon con niños apartamento Barranquilla',
    label: 'Balcon con niños',
    tipo: 'Protección niños',
  },
  {
    img: '/images/galeria-5.jpg',
    alt: 'Malla invisible para balcon conjunto residencial Barranquilla',
    label: 'Malla semi-invisible',
    tipo: 'Malla premium',
  },
  {
    img: '/images/galeria-6.jpg',
    alt: 'Instalación profesional malla seguridad apartamento piso alto',
    label: 'Piso alto seguro',
    tipo: 'Balcon alto',
  },
];
---

<section class="py-20 md:py-28 bg-ink-200/20" aria-labelledby="gallery-heading">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-14">
      <span class="section-label aos">Trabajos realizados</span>
      <h2 id="gallery-heading" class="section-title aos aos-delay-1 mx-auto">
        Instalaciones en<br>
        <span class="text-brand-dark">Barranquilla y el Atlántico</span>
      </h2>
      <p class="section-subtitle aos aos-delay-2 mx-auto text-center">
        Cada instalación es unica. Usamos el sistema de fijacion más adecuado
        para tu tipo de balcon, edificio y necesidad.
      </p>
    </div>

    <!-- Grid -->
    <div class="grid grid-cols-2 md:grid-cols-3 gap-3 md:gap-4">
      {works.map((w, i) => (
        <div
          class:list={[
            'group relative overflow-hidden rounded-2xl aspect-square bg-brand-50 aos',
            i < 2 ? '' : 'aos-delay-1',
          ]}
        >
          <img
            src={w.img}
            alt={w.alt}
            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
            loading="lazy"
            decoding="async"
            width="400"
            height="400"
          />
          <!-- Hover overlay -->
          <div class="absolute inset-0 bg-gradient-to-t from-ink-DEFAULT/80 via-transparent to-transparent
                      opacity-0 group-hover:opacity-100 transition-opacity duration-300">
            <div class="absolute bottom-0 left-0 right-0 p-4">
              <p class="text-white font-semibold text-sm leading-tight">{w.label}</p>
              <span class="inline-block mt-1 text-xs bg-brand/80 text-white px-2 py-0.5 rounded-full">
                {w.tipo}
              </span>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="text-center mt-10 aos">
      <a href="/galeria" class="btn-secondary inline-flex items-center gap-2">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <rect x="3" y="3" width="18" height="18" rx="2"/>
          <circle cx="8.5" cy="8.5" r="1.5"/>
          <polyline points="21 15 16 10 5 21"/>
        </svg>
        Ver galeria completa
      </a>
    </div>
  </div>
</section>
