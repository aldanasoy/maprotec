---
const photos = [
  { src: '/images/galeria-1.jpg', alt: 'Malla para balcón instalada en edificio Barranquilla', w: 600, h: 800 },
  { src: '/images/galeria-2.jpg', alt: 'Red de seguridad para terraza Barranquilla', w: 600, h: 400 },
  { src: '/images/galeria-3.jpg', alt: 'Malla para ventana Barranquilla', w: 600, h: 450 },
  { src: '/images/galeria-4.jpg', alt: 'Instalación malla para gatos Barranquilla', w: 600, h: 700 },
  { src: '/images/galeria-5.jpg', alt: 'Mallas de seguridad para niños Barranquilla', w: 600, h: 500 },
  { src: '/images/galeria-6.jpg', alt: 'Protección balcón apartamento Barranquilla', w: 600, h: 600 },
];
---

<section class="py-20 md:py-28 bg-ink-200/20" id="galeria" aria-labelledby="gallery-heading">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-6 mb-12">
      <div>
        <span class="section-label aos">Galeria de trabajos</span>
        <h2 id="gallery-heading" class="section-title aos aos-delay-1">
          Instalaciones reales<br />
          en Barranquilla
        </h2>
      </div>
      <a href="/galeria" class="btn-secondary aos flex-shrink-0">
        Ver todos los trabajos
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
    </div>

    <!-- Masonry-like grid -->
    <div class="columns-2 md:columns-3 gap-4 space-y-4">
      {photos.map((p, i) => (
        <div class={`aos aos-delay-${(i % 3)+1} break-inside-avoid rounded-2xl overflow-hidden group`}>
          <img
            src={p.src}
            alt={p.alt}
            width={p.w}
            height={p.h}
            class="w-full object-cover group-hover:scale-105 transition-transform duration-500 bg-brand-50"
            loading="lazy"
            decoding="async"
            onerror="this.style.display='none'; this.parentElement.style.background='#F0FDF4'; this.parentElement.style.minHeight='200px'; this.parentElement.style.display='flex'; this.parentElement.style.alignItems='center'; this.parentElement.style.justifyContent='center'; this.parentElement.innerHTML='<svg width=48 height=48 viewBox=\'0 0 24 24\' fill=none stroke=\'#059669\' stroke-width=1.5><rect x=3 y=3 width=18 height=18 rx=2/><circle cx=8.5 cy=8.5 r=1.5/><polyline points=\'21 15 16 10 5 21\'/></svg>'"
          />
        </div>
      ))}
    </div>

    <div class="mt-10 text-center aos">
      <a href="/galeria" class="btn-primary">
        Ver galeria completa
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
      </a>
    </div>
  </div>
</section>
