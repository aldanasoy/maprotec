---
const steps = [
  {
    n: '1',
    title: 'Contacto',
    desc: 'Escríbenos por WhatsApp o completa el formulario. Respondemos en menos de 2 horas en horario laboral.',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.63A2 2 0 012 1h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.91 8.08a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>`,
  },
  {
    n: '2',
    title: 'Visita y cotizacion',
    desc: 'Un técnico visita tu apartamento o casa, mide todos los espacios y te entrega un presupuesto detallado sin costo.',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>`,
  },
  {
    n: '3',
    title: 'Instalacion',
    desc: 'Nuestro equipo llega en la fecha acordada con todos los materiales. La instalación dura entre 2 y 4 horas para un apartamento.',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/></svg>`,
  },
  {
    n: '4',
    title: 'Garantia',
    desc: 'Emitimos un certificado de instalación con garantía de 1 año en materiales y mano de obra. Tu tranquilidad, respaldada.',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
  },
];
---

<section class="py-20 md:py-28 bg-white" id="proceso" aria-labelledby="process-heading">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <span class="section-label aos">Proceso</span>
      <h2 id="process-heading" class="section-title aos aos-delay-1 mx-auto">
        Cuatro pasos para<br />
        <span class="text-brand-dark">vivir más tranquilo</span>
      </h2>
      <p class="section-subtitle aos aos-delay-2 mx-auto text-center">
        Desde que nos contactas hasta la instalación final, el proceso es sencillo, rápido y sin sorpresas.
      </p>
    </div>

    <div class="relative">
      <!-- Connecting line (desktop) -->
      <div class="hidden lg:block absolute top-10 left-[12.5%] right-[12.5%] h-px bg-ink-200" aria-hidden="true"></div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8">
        {steps.map((s, i) => (
          <div class={`aos aos-delay-${i+1} flex flex-col items-center text-center`}>
            <!-- Circle -->
            <div class="relative mb-6">
              <div class="w-20 h-20 rounded-full bg-brand-dark text-white flex items-center justify-center shadow-lg z-10 relative" set:html={s.icon} />
              <span class="absolute -top-2 -right-2 w-6 h-6 bg-brand text-white text-xs font-bold rounded-full flex items-center justify-center">{s.n}</span>
            </div>
            <h3 class="font-display font-bold text-lg text-ink mb-2">{s.title}</h3>
            <p class="text-sm text-ink-600 leading-relaxed">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Mid-page CTA -->
    <div class="mt-16 text-center aos">
      <p class="text-ink-600 mb-4">Todo el proceso desde la primera llamada hasta la instalación puede ocurrir <strong class="text-ink">en menos de 48 horas</strong>.</p>
      <a href="/#contacto" class="btn-primary">
        Empezar ahora
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
    </div>
  </div>
</section>
