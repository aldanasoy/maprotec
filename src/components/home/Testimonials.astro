---
const reviews = [
  {
    name: 'María Fernández',
    role: 'Mamá de dos niños, El Prado',
    rating: 5,
    text: 'Contacté a Mayprotec un jueves y el viernes ya tenían instalada la malla en el balcón. Los técnicos fueron muy respetuosos, explicaron todo y la instalación quedó perfecta. Mis hijos ya pueden estar en el balcón sin que yo esté pendiente.',
    initial: 'M',
  },
  {
    name: 'Carlos Andrade',
    role: 'Dueño de gato, Manga',
    rating: 5,
    text: 'Mi gato se había escapado dos veces por la ventana. Desde que instalamos la malla de Mayprotec, está completamente seguro. La malla es casi invisible y el edificio no perdió nada de su estética. Lo recomiendo 100%.',
    initial: 'C',
  },
  {
    name: 'Sandra Ospino',
    role: 'Administradora de conjunto, Norte de Barranquilla',
    rating: 5,
    text: 'Contratamos Mayprotec para 8 apartamentos en nuestro conjunto. Trabajaron en orden, respetaron a los residentes y terminaron en el tiempo prometido. El precio fue muy competitivo y la calidad del material excelente.',
    initial: 'S',
  },
];
---

<section class="py-20 md:py-28 bg-white" id="testimonios" aria-labelledby="testimonials-heading">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <span class="section-label aos">Testimonios</span>
      <h2 id="testimonials-heading" class="section-title aos aos-delay-1 mx-auto">
        Lo que dicen<br />
        <span class="text-brand-dark">nuestros clientes</span>
      </h2>
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      {reviews.map((r, i) => (
        <blockquote class={`aos aos-delay-${i+1} card flex flex-col`}>
          <!-- Stars -->
          <div class="flex gap-0.5 mb-4" aria-label={`${r.rating} de 5 estrellas`}>
            {Array.from({ length: r.rating }).map(() => (
              <svg width="16" height="16" viewBox="0 0 24 24" fill="#F59E0B" aria-hidden="true">
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
              </svg>
            ))}
          </div>

          <!-- Quote -->
          <p class="text-ink-600 text-sm leading-relaxed flex-1">"{r.text}"</p>

          <!-- Author -->
          <footer class="mt-5 flex items-center gap-3 pt-5 border-t border-ink-200/60">
            <div class="w-10 h-10 rounded-full bg-brand-dark text-white flex items-center justify-center font-bold text-sm flex-shrink-0" aria-hidden="true">
              {r.initial}
            </div>
            <div>
              <cite class="font-semibold text-ink text-sm not-italic">{r.name}</cite>
              <p class="text-xs text-ink-400">{r.role}</p>
            </div>
          </footer>
        </blockquote>
      ))}
    </div>

    <!-- Google rating badge -->
    <div class="mt-12 flex justify-center aos">
      <div class="inline-flex items-center gap-3 bg-ink-200/30 rounded-2xl px-6 py-4">
        <svg width="24" height="24" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
          <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
          <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
          <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
        </svg>
        <div>
          <div class="flex items-center gap-1">
            {Array.from({ length: 5 }).map(() => (
              <svg width="14" height="14" viewBox="0 0 24 24" fill="#F59E0B" aria-hidden="true">
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
              </svg>
            ))}
            <span class="font-bold text-ink text-sm ml-1">5.0</span>
          </div>
          <p class="text-xs text-ink-600">+45 resenas en Google</p>
        </div>
      </div>
    </div>
  </div>
</section>
